# ===============================================
# ZEROLIFESTYLE BACKEND - Environment Variables
# ===============================================
#
# This file documents all environment variables.
# Copy this to .env and fill in your actual values.
# NEVER commit .env to version control!
#
# For Vercel Deployment:
# 1. Copy all variables below
# 2. Go to Vercel Dashboard > Project Settings > Environment Variables
# 3. Add each variable (excluding comments)
# 4. Redeploy your project
# ===============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# ===============================================
# DATABASE - MongoDB (Required)
# ===============================================
# Format: mongodb+srv://username:password@host/database?params
# Get your connection string from MongoDB Atlas dashboard
DATABASE_URL="mongodb+srv://zero:zero@cluster0.sxlknk7.mongodb.net/Zero-ecommerce?appName=Cluster0"

# ===============================================
# EMAIL CONFIGURATION - Gmail SMTP (Required for emails)
# ===============================================
# Note: Use "App Password" for Gmail, not your regular password
# Steps to get App Password:
# 1. Go to myaccount.google.com
# 2. Select Security
# 3. Enable 2-Factor Authentication
# 4. Search for "App passwords"
# 5. Generate password for Mail > Windows Computer
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# ===============================================
# JWT SECRETS - Authentication Tokens (Required)
# ===============================================
# Use strong, random strings (min 32 characters)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=your_super_secret_access_token_secret_min_32_chars
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_secret_min_32_chars
RESET_PASSWORD_SECRET=your_super_secret_reset_password_secret_min_32_chars

# ===============================================
# FRONTEND CONFIGURATION (Required)
# ===============================================
# Development: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ===============================================
# CLOUDINARY - Image Storage (Required for uploads)
# ===============================================
# Get credentials from cloudinary.com dashboard
# 1. Sign up at https://cloudinary.com
# 2. Go to Dashboard > API Keys
# 3. Copy Cloud Name, API Key, and API Secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===============================================
# OPTIONAL CONFIGURATIONS
# ===============================================

# Logging Level (development, production, test)
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cookie Settings
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=Lax
